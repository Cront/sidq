{
  "expo": {
    "name": "sidq-front-end",
    "slug": "sidq-front-end",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/sidqLogo.png",
    "scheme": "sidq",
    "owner": "sidqofficial",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sidqofficial.sidqfrontend"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/sidqLogo.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.sidqofficial.sidqfrontend"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/sidqLogo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
